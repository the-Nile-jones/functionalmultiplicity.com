# CF Pages _headers
# IMPORTANT: rules ACCUMULATE when multiple paths match, they do NOT override.
# Cache-Control: no `/*` catch-all — list HTML routes explicitly + use wildcards only for asset extensions
# (otherwise responses end up with multiple Cache-Control headers).
# Security headers below DO use `/*` because they're set in only one place — accumulation is harmless.

# === Security headers — applied to every response ===
/*
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'

# === Static assets — cache 1 year, content stable across deploys ===
# Note: NO `/pagefind/*` block — the extension rules below already cover pagefind's
# .js + .css files, and including both caused header accumulation (duplicate
# Cache-Control directive).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# === HTML pages — browser 1h, edge 1d, stale-while-revalidate 7d ===
# Why s-maxage=86400: cuts origin pulls without affecting browser TTL.
# Why stale-while-revalidate=604800: tolerates origin blips, refreshes in background.
# Picked moderate values after May 2026 stuck-cache incident with s-maxage=604800.
/
  Cache-Control: public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800, must-revalidate

/index.html
