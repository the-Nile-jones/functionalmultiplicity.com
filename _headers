# CF Pages _headers
# IMPORTANT: rules ACCUMULATE when multiple paths match, they do NOT override.
# So no `/*` catch-all — list HTML routes explicitly + use wildcards only for asset extensions.

# === Static assets — cache 1 year, content stable across deploys ===
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

